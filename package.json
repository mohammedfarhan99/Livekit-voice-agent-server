{
  "name": "livekit-voice-agent-server-hybrid",
  "version": "1.0.0",
  "description": "Production-ready hybrid LiveKit voice agent server (Node.js HTTP + Python Agents)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "setup-python": "cd python-agents && python -m venv venv && source venv/bin/activate && pip install -r requirements.txt",
    "start-python-workers": "cd python-agents && python workers/main.py start",
    "dev-python-workers": "cd python-agents && python workers/main.py dev",
    "test": "jest"
  },
  "dependencies": {
    "livekit-server-sdk": "^2.10.0",
    "express": "^4.18.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.4.0",
    "zod": "^3.22.0",
    "winston": "^3.11.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0"
  }
 
}